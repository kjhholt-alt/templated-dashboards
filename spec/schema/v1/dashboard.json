{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kjhholt-alt.github.io/templated-dashboards/schema/v1/dashboard.json",
  "title": "Dashboard IR v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "title", "sections"],
  "properties": {
    "version": { "const": "1" },
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string" },
    "theme": { "enum": ["palantir", "light"] },
    "footer": { "type": "string" },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/section" }
    }
  },
  "$defs": {
    "tone": { "enum": ["good", "warn", "bad", "neutral"] },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "components"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "subtitle": { "type": "string" },
        "layout": { "enum": ["stack", "grid"] },
        "components": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/component" }
        }
      }
    },
    "component": {
      "oneOf": [
        { "$ref": "#/$defs/status_card" },
        { "$ref": "#/$defs/kpi_tile" },
        { "$ref": "#/$defs/table" },
        { "$ref": "#/$defs/timeline" },
        { "$ref": "#/$defs/callout" },
        { "$ref": "#/$defs/chart" }
      ]
    },
    "status_card": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "project"],
      "properties": {
        "type": { "const": "status_card" },
        "project": { "type": "string", "minLength": 1 },
        "status_url": { "type": "string" },
        "inline_status": { "type": "object" }
      }
    },
    "kpi_tile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "label", "value"],
      "properties": {
        "type": { "const": "kpi_tile" },
        "label": { "type": "string", "minLength": 1 },
        "value": { "type": ["string", "number"] },
        "delta": { "type": "string" },
        "tone": { "$ref": "#/$defs/tone" }
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "headers", "rows"],
      "properties": {
        "type": { "const": "table" },
        "caption": { "type": "string" },
        "headers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": ["string", "number", "null"] }
          }
        }
      }
    },
    "timeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "events"],
      "properties": {
        "type": { "const": "timeline" },
        "events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["when", "title"],
            "properties": {
              "when": { "type": "string" },
              "title": { "type": "string" },
              "detail": { "type": "string" },
              "tone": { "$ref": "#/$defs/tone" }
            }
          }
        }
      }
    },
    "callout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "text"],
      "properties": {
        "type": { "const": "callout" },
        "text": { "type": "string" },
        "tone": { "$ref": "#/$defs/tone" },
        "icon": { "type": "string" }
      }
    },
    "chart": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "kind", "series"],
      "properties": {
        "type": { "const": "chart" },
        "kind": { "enum": ["bar", "line", "sparkline"] },
        "caption": { "type": "string" },
        "series": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "points"],
            "properties": {
              "label": { "type": "string" },
              "points": {
                "type": "array",
                "items": { "type": "number" }
              }
            }
          }
        }
      }
    }
  }
}
